      "ingredients": [
        { "displayName": "Pan de barra", "canonicalName": "pan" },
        { "displayName": "Tomate maduro", "canonicalName": "tomate" },
        { "displayName": "Ajo", "canonicalName": "ajo" },
        { "displayName": "Aceite de oliva virgen extra", "canonicalName": "aceite de oliva" },
        { "displayName": "Sal gruesa", "canonicalName": "sal" }
      ],
      "recipe": {
        "servings": 4,
        "ingredients": [
          { "name": "Pan de barra", "quantity": "1 unidad" },
          { "name": "Tomate maduro", "quantity": "3 unidades grandes" },
          { "name": "Ajo", "quantity": "2 dientes" },
          { "name": "Aceite de oliva virgen extra", "quantity": "4 cucharadas" },
          { "name": "Sal gruesa", "quantity": "al gusto" }
        ],
        "steps": {
          "type": "doc",
          "content": [
            {
              "type": "heading",
              "attrs": { "level": 2 },
              "content": [
                {
                  "type": "text",
                  "marks": [{ "type": "textStyle", "attrs": { "color": "#4338ca" } }],
                  "text": "Elaboración"
                }
              ]
            },
            {
              "type": "orderedList",
              "attrs": { "start": 1 },
              "content": [
                {
                  "type": "listItem",
                  "content": [{ "type": "paragraph", "content": [
                    { "type": "text", "marks": [{ "type": "bold" }], "text": "Corta " },
                    { "type": "text", "text": "el pan en rebanadas de 1,5 cm y tuéstalas en una sartén o tostadora hasta que estén bien doradas por ambas caras." }
                  ]}]
                },
                {
                  "type": "listItem",
                  "content": [{ "type": "paragraph", "content": [
                    { "type": "text", "marks": [{ "type": "bold" }], "text": "Frota el ajo " },
                    { "type": "text", "text": "pelado sobre la cara tostada de la rebanada mientras aún está caliente. Usa más o menos cantidad según el gusto." }
                  ]}]
                },
                {
                  "type": "listItem",
                  "content": [{ "type": "paragraph", "content": [
                    { "type": "text", "marks": [{ "type": "bold" }], "text": "Parte los tomates " },
                    { "type": "text", "text": "por la mitad y frota con fuerza sobre el pan hasta que absorba toda la pulpa. Desecha la piel." }
                  ]}]
                },
                {
                  "type": "listItem",
                  "content": [{ "type": "paragraph", "content": [
                    { "type": "text", "marks": [{ "type": "bold" }], "text": "Aliña " },
                    { "type": "text", "text": "con un buen chorro de aceite de oliva virgen extra y una pizca de sal gruesa justo antes de servir." }
                  ]}]
                }
              ]
            },

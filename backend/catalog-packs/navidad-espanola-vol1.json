            },
            {
              "type": "orderedList",
              "attrs": { "start": 1 },
              "content": [
                {
                  "type": "listItem",
                  "content": [{ "type": "paragraph", "content": [
                    { "type": "text", "marks": [{ "type": "bold" }], "text": "Prepara la ajada: " },
                    { "type": "text", "text": "pica el ajo y el perejil muy fino, mézclalos con el aceite y reserva. Esta salsa se añade en crudo al final." }
                  ]}]
                },
                {
                  "type": "listItem",
                  "content": [{ "type": "paragraph", "content": [

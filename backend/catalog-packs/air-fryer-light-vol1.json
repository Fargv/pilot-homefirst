              { "type": "listItem", "content": [{ "type": "paragraph", "content": [
                { "type": "text", "marks": [{ "type": "bold" }], "text": "Rocía ligeramente con aceite en spray. Cocina a " },
                { "type": "text", "marks": [{ "type": "textStyle", "attrs": { "color": "#f97316" } }], "text": "200 °C durante 10-12 min" },
                { "type": "text", "text": ", dando la vuelta a los " },
                { "type": "text", "marks": [{ "type": "textStyle", "attrs": { "color": "#f97316" } }], "text": "6 min" },
                { "type": "text", "text": ". La costra debe quedar dorada y crujiente." }
              ]}] },
              { "type": "listItem", "content": [{ "type": "paragraph", "content": [
                { "type": "text", "marks": [{ "type": "bold" }], "text": "Sirve con gajos de limón " },
                { "type": "text", "text": "y ensalada verde o puré de guisantes." }
              ]}] }
            ]},
            { "type": "paragraph", "content": [{ "type": "text", "marks": [{ "type": "textStyle", "attrs": { "color": "#22c55e" } }], "text": "✔ Truco: el panko en vez de pan rallado fino es la diferencia entre una costra crujiente y una blanda." }] }
          ]
        }
      }

{
  "permissions": {
    "allow": [
      "Bash",
      "PowerShell",
      "Edit",
      "Write",
      "Read",
      "WebSearch",
      "WebFetch",
      "Skill",
      "Bash(git commit *)",
      "Bash(rm -f \".git/COMMIT_EDITMSG_TEMP.txt\")",
      "Bash(git add *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Bash(rm -rf:*)",
      "PowerShell(Remove-Item *)"
    ],
    "ask": [
      "Bash(git push:*)",
      "PowerShell(git push:*)"
    ]
  }
}

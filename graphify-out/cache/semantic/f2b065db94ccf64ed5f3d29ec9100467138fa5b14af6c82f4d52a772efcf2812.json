{"nodes": [{"id": "impeccable_skill", "label": "Impeccable Skill (SKILL.md)", "file_type": "document", "source_file": ".claude/skills/impeccable/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "impeccable_skill_shared_design_laws", "label": "Impeccable Shared Design Laws", "file_type": "rationale", "source_file": ".claude/skills/impeccable/SKILL.md", "source_location": "## Shared design laws", "source_url": null, "captured_at": null, "author": null, "contributor": "impeccable_skill", "rationale": "Universal design rules applying to both brand and product registers: OKLCH color with chroma reduction at extremes; dark/light theme chosen from physical scene sentence not default; 65-75ch body line length; varied spacing for rhythm; motion via ease-out-quart/quint/expo; absolute bans on side-stripe borders, gradient text, glassmorphism, hero-metric template, identical card grids, modal-as-first-thought."}, {"id": "impeccable_skill_ai_slop_test", "label": "AI Slop Test Principle", "file_type": "rationale", "source_file": ".claude/skills/impeccable/SKILL.md", "source_location": "### The AI slop test", "source_url": null, "captured_at": null, "author": null, "contributor": "impeccable_skill", "rationale": "Two-altitude reflex check: first-order catches domain-predictable palette (e.g. 'observability -> dark blue'); second-order catches aesthetic-family predictability after avoiding first-order (e.g. 'fintech avoiding navy-gold -> terminal dark mode'). Both must fail before the design passes."}, {"id": "impeccable_skill_register_concept", "label": "Design Register Concept (Brand vs Product)", "file_type": "concept", "source_file": ".claude/skills/impeccable/SKILL.md", "source_location": "### 2. Register", "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "impeccable_skill", "target": "reference_adapt", "relation": "references", "confidence": "EXTRACTED